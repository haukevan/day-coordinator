generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  supabaseId    String   @unique
  email         String   @unique
  name          String?
  firstName     String?
  lastName      String?
  company       String?
  phone         String?
  phoneVerified Boolean  @default(false)
  avatar        String?
  onboarded     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedEvents  Event[]       @relation("EventOwner")
  assignedTasks Task[]       @relation("AssignedTo")
  activityLogs ActivityLog[]
}

// ─── Event ───────────────────────────────────────────────────────────────────

model Event {
  id             String        @id @default(cuid())
  title          String
  description    String?
  eventDate      DateTime?
  timezone       String        @default("UTC")
  slug           String?       @unique
  status         EventStatus   @default(DRAFT)
  paymentStatus  PaymentStatus @default(FREE)
  publicTimeline Boolean       @default(false)
  liveStartedAt  DateTime?
  ownerId        String
  owner          User          @relation("EventOwner", fields: [ownerId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tasks         Task[]
  notifications Notification[]
  activityLogs  ActivityLog[]
}

enum EventStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  ARCHIVED
}

enum PaymentStatus {
  FREE
  PAID
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id               String     @id @default(cuid())
  eventId          String
  event            Event      @relation(fields: [eventId], references: [id])
  title            String
  description      String?
  status           TaskStatus @default(PENDING)
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  actualStart      DateTime?
  actualEnd        DateTime?
  durationMins     Int?
  manualOverride   Boolean    @default(false)
  publicVisibility Boolean    @default(false)
  parentTaskId     String?
  parentTask       Task?      @relation("TaskDependency", fields: [parentTaskId], references: [id])
  childTasks       Task[]     @relation("TaskDependency")
  assignedToId     String?
  assignedTo       User?      @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  activityLogs ActivityLog[]
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
  SKIPPED
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id             String              @id @default(cuid())
  eventId        String
  event          Event               @relation(fields: [eventId], references: [id])
  type           NotificationType
  channel        NotificationChannel
  recipient      String
  payload        Json
  status         NotificationStatus  @default(PENDING)
  idempotencyKey String              @unique
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

enum NotificationType {
  TASK_REMINDER
  TASK_DELAYED
  EVENT_STARTED
  CUSTOM
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}

